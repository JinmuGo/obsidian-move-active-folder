{
  "name": "obsidian-move-active-folder",
  "version": "1.0.0",
  "description": "Move the folder containing the currently active file.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "version": "node version-bump.mjs && git add manifest.json versions.json",
    "test": "jest",
    "lint": "biome check src",
    "format": "biome check --write src"
  },
  "keywords": [
    "obsidian",
    "plugin"
  ],
  "author": "Jinmu Go",
  "license": "0BSD",
  "packageManager": "pnpm@11.0.3",
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "@types/jest": "^30.0.0",
    "@types/node": "^16.11.6",
    "esbuild": "0.17.3",
    "jest": "^30.2.0",
    "obsidian": "latest",
    "ts-jest": "^29.4.6",
    "tslib": "2.4.0",
    "typescript": "5.9.3"
  }
}